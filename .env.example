# ── Domínio principal do app ──────────────────────────────────────────────────
# App em causi.adv.br; LPs publicadas em {escritorio}.causi.adv.br/{slug}
# Pode incluir protocolo (https://causi.adv.br) ou só o host (causi.adv.br)
APP_URL=https://causi.adv.br
# Domínio base das LPs públicas: {escritorio}.{NEXT_PUBLIC_APP_DOMAIN}/{slug}
# Em dev local use localhost (ex.: ana-roberta-teste.localhost:3000/meu-tema)
NEXT_PUBLIC_APP_DOMAIN=causi.adv.br

# ── Causi — Supabase Auth (Projeto A) ────────────────────────────────────────
# URL e chave pública do Supabase do Causi (quem autentica os usuários)
NEXT_PUBLIC_SUPABASE_URL=https://<CAUSI_PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<causi_anon_key>

# ── Gerador — banco de LPs (Projeto B) ───────────────────────────────────────
# URL e chaves do Supabase separado onde ficam as landing pages
LP_SUPABASE_URL=https://<LP_PROJECT_REF>.supabase.co
LP_SUPABASE_ANON_KEY=<lp_anon_key>
# Settings → API → JWT Secret (para assinar tokens com claims de conta/role)
LP_SUPABASE_JWT_SECRET=<lp_jwt_secret>
LP_SUPABASE_SERVICE_ROLE_KEY=<lp_service_role_key>

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Tarefas simples/repetitivas: copy, melhorar-texto, ranking de imagens, paletas
OPENAI_MODEL_CHAT=gpt-4.1-mini
# Raciocínio: escolha de layout (variantes/tons) na criação da LP
OPENAI_MODEL_REASONING=gpt-5-mini

# ── Unsplash ──────────────────────────────────────────────────────────────────
# Crie em https://unsplash.com/developers → New Application → Access Key
# Sem ela, imagens de cenário ficam vazias (upload manual continua valendo)
UNSPLASH_ACCESS_KEY=

# ── Cloudflare Turnstile (global, formulários de lead nas LPs) ───────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Suporte ───────────────────────────────────────────────────────────────────
# WhatsApp de suporte (somente dígitos, ex.: 5511999999999)
NEXT_PUBLIC_SUPPORT_WHATSAPP=
